[global]
monitor = 0
follow = mouse
width = 340
height = 240
origin = bottom-center
offset = 0x28
scale = 0
notification_limit = 6

progress_bar = true
progress_bar_height = 6
progress_bar_frame_width = 1
progress_bar_min_width = 150
progress_bar_max_width = 300

indicate_hidden = yes
transparency = 8
separator_height = 2
padding = 12
horizontal_padding = 12
text_icon_padding = 10
frame_width = 2
frame_color = "#7f5963"
separator_color = frame
corner_radius = 12

font = JetBrainsMono Nerd Font 10
line_height = 1
markup = full
format = "<b>%s</b>\n%b"
alignment = left
vertical_alignment = center
show_age_threshold = 60
word_wrap = yes
ellipsize = middle
ignore_newline = no
stack_duplicates = true
hide_duplicate_count = false
show_indicators = yes
icon_position = left
min_icon_size = 28
max_icon_size = 48
icon_path = /usr/share/icons/Papirus-Dark/16x16/status/:/usr/share/icons/Papirus-Dark/16x16/apps/:/usr/share/icons/Papirus-Dark/16x16/devices/
sticky_history = yes
history_length = 40
browser = xdg-open
always_run_script = true
title = Dunst
class = Dunst
corner_radius = 10
ignore_dbusclose = false

[experimental]
per_monitor_dpi = false

[urgency_low]
background = "#cc101621"
foreground = "#e4ebf3"
frame_color = "#7f5963"
timeout = 3

[urgency_normal]
background = "#dd1c1f2c"
foreground = "#e4ebf3"
frame_color = "#7f5963"
timeout = 5

[urgency_critical]
background = "#dd1c1f2c"
foreground = "#e4ebf3"
frame_color = "#8c5a64"
timeout = 0
