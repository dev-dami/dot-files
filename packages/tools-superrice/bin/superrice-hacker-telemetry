#!/usr/bin/env bash
set -euo pipefail

while :; do
  clear
  printf '\033[1;36mtelemetry\033[0m\n\n'
  acpi -b 2>/dev/null || echo "Battery: unavailable"
  printf '\n'
  if command -v wpctl >/dev/null 2>&1; then
    wpctl get-volume @DEFAULT_AUDIO_SINK@ 2>/dev/null || true
  fi
  printf '\n'
  free -h
  sleep 1
done
