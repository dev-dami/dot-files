#!/usr/bin/env bash
set -euo pipefail

command -v i3-msg >/dev/null 2>&1 || exit 0
command -v jq >/dev/null 2>&1 || exit 0

icon_for_num() {
  case "$1" in
    1) echo "’äĀ" ;;
    2) echo "’ē®" ;;
    3) echo "’äĪ" ;;
    4) echo "’ü╝" ;;
    5) echo "’Ćü" ;;
    6) echo "’ć╝" ;;
    7) echo "’āĀ" ;;
    8) echo "’éå" ;;
    9) echo "’äø" ;;
    *) echo "’äæ" ;;
  esac
}

icon_for_class() {
  local c
  c="$(tr '[:upper:]' '[:lower:]' <<<"${1:-}")"
  case "$c" in
    kitty|alacritty|wezterm|foot|terminator) echo "’äĀ" ;;
    firefox|zen|zen-browser|google-chrome|chromium|brave-browser) echo "’ē®" ;;
    code|code-oss|codium|nvim|emacs|sublime_text|jetbrains*) echo "’äĪ" ;;
    thunar|nemo|nautilus|pcmanfm) echo "’ü╝" ;;
    spotify|vlc|mpv|rhythmbox|strawberry) echo "’Ćü" ;;
    discord|slack|telegramdesktop|signal|vesktop|whatsapp-for-linux) echo "’éå" ;;
    steam|lutris|heroic|prismlauncher) echo "’äø" ;;
    gimp|krita|inkscape|blender) echo "’ć╝" ;;
    obsidian) echo "¾▒×ü" ;;
    *) echo "" ;;
  esac
}

sync_once() {
  local tree rows row num name class icon target
  tree="$(i3-msg -t get_tree 2>/dev/null || true)"
  [ -n "$tree" ] || return 0

  mapfile -t rows < <(
    jq -r '
      def walk:
        . as $n
        | [$n]
          + (((($n.nodes // []) | map(walk) | add) // []))
          + (((($n.floating_nodes // []) | map(walk) | add) // []));

      [walk[] | select(.type == "workspace" and .num > 0)]
      | sort_by(.num)
      | .[] as $ws
      | ([$ws | walk[] | select(.window_properties.class? != null)]) as $wins
      | (($wins | map(select(.focused == true) | .window_properties.class) | .[0])
         // ($wins | map(.window_properties.class) | .[0])
         // "") as $class
      | "\($ws.num)\t\($ws.name)\t\($class)"
    ' <<<"$tree"
  )

  for row in "${rows[@]}"; do
    IFS=$'\t' read -r num name class <<<"$row"
    [ -n "${num:-}" ] || continue

    icon="$(icon_for_class "${class:-}")"
    [ -n "$icon" ] || icon="$(icon_for_num "$num")"
    target="${num}:${icon}"

    if [ "$name" != "$target" ]; then
      i3-msg --quiet "rename workspace \"$name\" to \"$target\"" >/dev/null 2>&1 || true
    fi
  done
}

while :; do
  sync_once
  sleep 2
done
